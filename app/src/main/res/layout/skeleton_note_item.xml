<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorBackground"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/colorCardBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Skeleton for Name -->
            <View
                android:id="@+id/skeletonName"
                android:layout_width="120dp"
                android:layout_height="16dp"
                android:background="@drawable/shimmer_placeholder"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Skeleton for Class -->
            <View
                android:id="@+id/skeletonClass"
                android:layout_width="80dp"
                android:layout_height="14dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/shimmer_placeholder"
                app:layout_constraintTop_toBottomOf="@id/skeletonName"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Skeleton for Title -->
            <View
                android:id="@+id/skeletonTitle"
                android:layout_width="0dp"
                android:layout_height="18dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/shimmer_placeholder"
                app:layout_constraintTop_toBottomOf="@id/skeletonClass"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.7" />

            <!-- Skeleton for Description Line 1 -->
            <View
                android:id="@+id/skeletonDesc1"
                android:layout_width="0dp"
                android:layout_height="14dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/shimmer_placeholder"
                app:layout_constraintTop_toBottomOf="@id/skeletonTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Skeleton for Description Line 2 -->
            <View
                android:id="@+id/skeletonDesc2"
                android:layout_width="0dp"
                android:layout_height="14dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/shimmer_placeholder"
                app:layout_constraintTop_toBottomOf="@id/skeletonDesc1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.8" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
